# DATABASE_URL: Use Supabase Postgres for MVP staging/production.
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?pgbouncer=true&connection_limit=1"

# Supabase Auth / Postgres project settings.
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Stripe: Use test keys in local/staging and live keys only in production.
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_STARTER_MONTHLY="price_..."
STRIPE_PRICE_PRO_MONTHLY="price_..."
STRIPE_PRICE_CREDIT_PACK_SMALL="price_..."
STRIPE_PRICE_CREDIT_PACK_MEDIUM="price_..."

# APP_URL / FRONTEND_URL: Used for Stripe redirects, CORS, and public links.
APP_URL="http://localhost:3000"
FRONTEND_URL="http://localhost:3000"

# Optional free-tier services for MVP operations.
RESEND_API_KEY="re_..."
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN="..."
