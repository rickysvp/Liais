generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile         Profile?
  subscriptions   Subscription[]
  usageLog        UsageLedger[]
  onboardingDraft OnboardingDraft?
}

model Profile {
  id                        String   @id @default(uuid())
  userId                    String   @unique
  slug                      String   @unique
  displayName               String
  headline                  String?
  companyOrProject          String?
  city                      String?
  whatYouDo                 String?
  whoYouHelp                String?
  currentFocus              String?
  topicsYouLike             String?
  websiteUrl                String?
  linkedinUrl               String?
  twitterUrl                String?
  generatedIntro            String?
  generatedWelcomeMessage   String?
  generatedContactScopeText String?
  primaryConnectionGoal     String?
  personaType               String?
  secretaryTone             String?
  greetingStyle             String?
  screeningStyle            String?
  isPublished               Boolean  @default(false)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  user                 User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferences          ProfileConnectionPreference[]
  boundaries           ProfileBoundary[]
  visitorConversations VisitorConversation[]
  secretaryMessages    SecretaryMessage[]

  @@index([isPublished])
}

model ProfileConnectionPreference {
  id        String @id @default(uuid())
  profileId String
  type      String
  status    String

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model ProfileBoundary {
  id             String @id @default(uuid())
  profileId      String
  category       String
  value          String
  visibilityType String

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model OnboardingDraft {
  id               String   @id @default(uuid())
  sessionId        String?
  userId           String?  @unique
  step             Int      @default(1)
  payload          String
  previewGenerated Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])

  @@index([sessionId])
}

model VisitorConversation {
  id                    String   @id @default(uuid())
  profileId             String
  visitorName           String?
  visitorCompany        String?
  visitorBackground     String?
  visitorReason         String?
  visitorIntentCategory String?
  requestedNextStep     String?
  contactInfo           String?
  transcript            String
  summaryText           String?
  qualificationLevel    String?
  suggestedAction       String?
  handoffNeeded         Boolean  @default(false)
  status                String   @default("new")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([status])
  @@index([profileId, status])
}

model UsageLedger {
  id             String   @id @default(uuid())
  userId         String
  conversationId String?
  actionType     String
  creditsDelta   Int
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Subscription {
  id             String   @id @default(uuid())
  userId         String
  planName       String   @default("Free")
  status         String   @default("active")
  monthlyCredits Int      @default(10)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SecretaryMessage {
  id        String   @id @default(uuid())
  profileId String
  role      String
  content   String
  createdAt DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([profileId, createdAt])
}
