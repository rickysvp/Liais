{
  "name": "react-example",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --platform=node --format=cjs --bundle --external:vite --external:express --external:cors --external:@prisma/client --external:dotenv --outfile=dist/server.cjs",
