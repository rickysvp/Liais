    "@types/supertest": "^7.2.0",
    "autoprefixer": "^10.4.21",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
